# ================================================================
# Docker Compose 環境変数
# このファイルを .env にコピーして値を設定してください
#   cp docker/.env.example .env
# ================================================================

# ─── MySQL ─────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=your-secure-root-password-here
MYSQL_DATABASE=sportsday
MYSQL_USER=sportsday
MYSQL_PASSWORD=your-secure-app-password-here

# ─── CORS (カンマ区切りで複数指定可) ──────────────────
CORS_ORIGINS=https://your-domain.example.com

# ─── Microsoft Entra ID ───────────────────────────────
AUTH_ISSUER_URL=https://login.microsoftonline.com/{tenant-id}/v2.0
AUTH_CLIENT_ID=your-entra-app-client-id
AUTH_ROLE_CACHE_TTL=60

# ─── RustFS / S3 Storage ─────────────────────────────
STORAGE_ACCESS_KEY=your-storage-access-key
STORAGE_SECRET_KEY=your-storage-secret-key
STORAGE_PUBLIC_ENDPOINT=https://your-domain.example.com
STORAGE_REGION=us-east-1
STORAGE_BUCKET=storage
STORAGE_WEBHOOK_SECRET=your-webhook-secret

# ─── Grafana ──────────────────────────────────────────
# Grafana 管理者パスワード（初回起動時に設定される）
# http://<server-ip>:3000 でアクセス可能
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-secure-grafana-password
# 外部からアクセスする場合はドメイン名を設定（例: grafana.your-domain.com）
GRAFANA_DOMAIN=localhost

# ─── タイムゾーン ─────────────────────────────────────
TZ=Asia/Tokyo

# ─── データ保存先 (VM上の絶対パス推奨) ───────────────
# Proxmox VMのセカンダリディスクにマウントしたパスを指定
DATA_DIR=/opt/sportsday-data

# ================================================================
# 初回セットアップ時に必要な手順
# ================================================================
# 1. このファイルを .env にコピー: cp docker/.env.example .env
# 2. .env の各値を設定する
# 3. データディレクトリのパーミッションを設定する（Loki/Grafana用）:
#
#   export DATA_DIR=/opt/sportsday-data  # .envのDATA_DIRと合わせる
#   mkdir -p ${DATA_DIR}/loki ${DATA_DIR}/grafana
#   chown 10001:10001 ${DATA_DIR}/loki    # Loki UID
#   chown 472:472     ${DATA_DIR}/grafana # Grafana UID
#
# 4. 起動:
#   docker compose up -d
#   （docker-compose.yml に name: sports-day を明記しているので
#     プロジェクト名は自動的に sports-day になる）
# ================================================================
